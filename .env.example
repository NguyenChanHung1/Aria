# Optional: LLM-powered planning and lyrics. Leave empty to use built-in templates.
OPENAI_API_KEY=

# Optional: override service URLs when running services locally outside Docker
NEXT_PUBLIC_AGENT_API_URL=http://localhost:8000
AGENT_API_URL=http://localhost:8000
LYRICS_SERVICE_URL=http://localhost:8001
COMPOSITION_SERVICE_URL=http://localhost:8002
MIXING_SERVICE_URL=http://localhost:8003

DATABASE_URL=postgresql://aria:aria@localhost:5432/aria
REDIS_URL=redis://localhost:6379

# Prisma metadata and S3-compatible artifact storage
MINIO_ROOT_USER=aria-minio
MINIO_ROOT_PASSWORD=aria-minio-development
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=aria-artifacts
OBJECT_STORAGE_ACCESS_KEY=aria-minio
OBJECT_STORAGE_SECRET_KEY=aria-minio-development
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=900
